<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashScreen">

    <fragment
        android:id="@+id/splashScreen"
        android:name="com.me.mcqai.ui.SplashScreen"
        android:label="fragment_splash_screen"
        tools:layout="@layout/fragment_splash_screen">
        <action
            android:id="@+id/action_splashScreen_to_homeScreen"
            app:destination="@id/homeScreen"
            app:popUpTo="@id/splashScreen"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splashScreen_to_welcomeScreen"
            app:destination="@id/welcomeScreen"
            app:popUpTo="@id/splashScreen"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeScreen"
        android:name="guru.mcqai.www.HomeScreen"
        android:label="fragment_home_screen"
        tools:layout="@layout/fragment_home_screen" >
        <action
            android:id="@+id/action_homeScreen_to_welcomeScreen"
            app:destination="@id/welcomeScreen" />
        <action
            android:id="@+id/action_homeScreen_to_mcqScreen"
            app:destination="@id/mcqScreen" />
    </fragment>
    <fragment
        android:id="@+id/mcqScreen"
        android:name="guru.mcqai.www.McqScreen"
        android:label="fragment_mcq_screen"
        tools:layout="@layout/fragment_mcq_screen" >
        <argument
            android:name="data"
            app:argType="string"
            app:nullable="true"
            />

        <action
            android:id="@+id/action_mcqScreen_to_scoreScreen"
            app:destination="@id/scoreScreen" />
        <action
            android:id="@+id/action_mcqScreen_to_bottomSheetResultFragment"
            app:destination="@id/bottomSheetResultFragment" />
    </fragment>
    <fragment
        android:id="@+id/scoreScreen"
        android:name="guru.mcqai.www.ScoreScreen"
        android:label="fragment_score_screen"
        tools:layout="@layout/fragment_score_screen" >
    </fragment>
    <dialog
        android:id="@+id/bottomSheetResultFragment"
        android:name="com.me.mcqai.ui.BottomSheetResultFragment"
        android:label="fragment_bottom_sheet_result"
        tools:layout="@layout/fragment_bottom_sheet_result" />
    <fragment
        android:id="@+id/welcomeScreen"
        android:name="com.me.mcqai.ui.WelcomeScreen"
        android:label="fragment_welcome_screen"
        tools:layout="@layout/fragment_welcome_screen" >
        <action
            android:id="@+id/action_welcomeScreen_to_examSelectionScreen"
            app:destination="@id/examSelectionScreen" />
    </fragment>

    <fragment
        android:id="@+id/examSelectionScreen"
        android:name="com.me.mcqai.ui.ExamSelectionScreen"
        android:label="fragment_exam_selection_screen"
        tools:layout="@layout/fragment_exam_selection_screen" >
        <action
            android:id="@+id/action_examSelectionScreen_to_difficultyScreen"
            app:destination="@id/difficultyScreen" />
    </fragment>


    <fragment
        android:id="@+id/difficultyScreen"
        android:name="com.me.mcqai.ui.DifficultyScreen"
        android:label="DifficultyScreen"
        tools:layout="@layout/fragment_difficulty_screen"
        >
        <action
            android:id="@+id/action_difficultyScreen_to_homeScreen"
            app:destination="@id/homeScreen" />
        <argument
            android:name="data"
            app:argType="string" />
    </fragment>

</navigation>